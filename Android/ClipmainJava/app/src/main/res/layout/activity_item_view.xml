<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ItemViewActivity">

    <ImageButton
        android:id="@+id/imageButtonClose"
        android:layout_width="40dp"
        android:layout_height="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:src="@drawable/buttonexit"
        android:scaleType="fitCenter"
        android:background="@drawable/button_border"
        app:backgroundTint="@null"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="10dp"
        android:onClick="Click_buttonBackToShop"/>

    <TextView
        android:id="@+id/textViewItemTitleTopInItem"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:textSize="25sp"
        app:layout_constraintLeft_toRightOf="@id/imageButtonClose"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="13dp"
        android:layout_marginLeft="10dp"/>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerItems"
        android:layout_width="400dp"
        android:layout_height="350dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="60dp"/>

    <com.tbuonomo.viewpagerdotsindicator.SpringDotsIndicator
        android:id="@+id/dotsIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:dotsColor="#555555"
        app:dotsCornerRadius="50dp"
        app:dotsSize="10dp"
        app:dotsSpacing="6dp"
        app:dotsStrokeColor="#333333"
        app:progressMode="true"
        app:selectedDotColor="#363676"
        app:layout_constraintTop_toBottomOf="@id/viewPagerItems"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>


    <TextView
        android:id="@+id/textViewItemTitleInItem"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/viewPagerItems"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="28dp"/>

    <TextView
        android:id="@+id/textViewItemPriceInItem"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/textViewItemTitleInItem"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="15dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycleViewSizesInItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:clickable="false"
        android:focusable="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/textViewItemPriceInItem"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="15dp"
        tools:listitem="@layout/item_size_chip"/>

    <TextView
        android:id="@+id/textViewItemDescriptionInItem"
        android:layout_width="400dp"
        android:layout_height="50dp"
        android:textSize="16sp"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/recycleViewSizesInItem"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="15dp"/>

    <Button
        android:id="@+id/buttonAddInCart"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:text="Buy"
        android:textSize="20sp"
        android:backgroundTint="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginBottom="10dp"
        android:onClick="Click_buttonAddToBasket"/>


</androidx.constraintlayout.widget.ConstraintLayout>