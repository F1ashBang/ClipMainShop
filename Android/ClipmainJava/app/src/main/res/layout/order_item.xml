<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/textViewOrderIdInOrder"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Заказ №15"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121"/>

            <TextView
                android:id="@+id/textViewStatusInOrder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="В пути"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/textViewItemsCountInOrder"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="3 товара"
                android:textSize="14sp"
                android:textColor="#888888"/>

            <TextView
                android:id="@+id/textViewOrderTotalInOrder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="17 997 ₽"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#363676"/>
        </LinearLayout>

        <TextView
            android:id="@+id/textViewOrderDateInOrder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15.05.2026"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>