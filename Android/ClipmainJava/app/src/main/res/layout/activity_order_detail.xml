<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:layout_marginTop="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/imageButtonBackFromDetail"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/buttonexit"
            android:background="#00000000"
            android:scaleType="centerCrop"/>

        <TextView
            android:id="@+id/textViewDetailTitleInOrderDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Заказ №15"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginLeft="8dp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Статус заказа"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/textViewDetailStatusInOrderDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚚 В пути"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Получатель"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/textViewDetailNameInOrderDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Петров Иван Сергеевич"
                        android:textSize="15sp"
                        android:textColor="#212121"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/textViewDetailPhoneInOrderDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+7 999 123-45-67"
                        android:textSize="14sp"
                        android:textColor="#363676"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Адрес доставки"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/textViewDetailAddressInOrderDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="г. Москва, ул. Тверская, д. 1, кв. 42"
                        android:textSize="15sp"
                        android:textColor="#212121"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Товары"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="8dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewDetailItemsInOrderDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Итого"
                            android:textSize="16sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/textViewDetailTotalInOrderDetails"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="17 997 ₽"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#363676"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/buttonCancelOrder"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Отменить заказ"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#F44336"
                android:backgroundTint="#FFFFFF"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:onClick="Click_cancelOrder"/>

            <TextView
                android:id="@+id/textViewDetailDateInOrderDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Заказ создан: 15.05.2026"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:layout_gravity="center"/>

        </LinearLayout>
    </ScrollView>


</LinearLayout>