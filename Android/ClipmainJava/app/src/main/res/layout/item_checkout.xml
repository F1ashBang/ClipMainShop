<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/imageViewCheckoutItem"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingLeft="12dp">

        <TextView
            android:id="@+id/textViewCheckoutTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="title"
            android:textColor="#212121"/>

        <TextView
            android:id="@+id/textViewCheckoutPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:text="price"
            android:textColor="#888888"/>

        <TextView
            android:id="@+id/textViewCheckoutDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:text="details"
            android:textColor="#888888"/>

    </LinearLayout>

    <TextView
        android:id="@+id/textViewCheckoutTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:text="total"
        android:textStyle="bold"
        android:textColor="#363676"/>

</LinearLayout>