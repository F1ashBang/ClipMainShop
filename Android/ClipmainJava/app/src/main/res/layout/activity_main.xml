<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/textViewMainInscription"
        android:layout_width="250dp"
        android:layout_height="150dp"
        android:src="@drawable/logostock"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginTop="250dp"/>

    <EditText
        android:id="@+id/editTextPhoneNumber"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="Phone number"
        app:layout_marginBaseline="5dp"
        android:textSize="30sp"
        android:maxLines="1"
        android:background="@drawable/edit_text_border"
        app:layout_constraintTop_toBottomOf="@id/textViewMainInscription"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginTop="50dp"/>

    <Button
        android:id="@+id/buttonSignUp"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:text="Sign up"
        android:textSize="20sp"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toBottomOf="@id/editTextPhoneNumber"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="30dp"
        android:onClick="Click_buttonSignUp"/>

    <Button
        android:id="@+id/buttonLogIn"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:text="Log in"
        android:textSize="20sp"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toBottomOf="@id/buttonSignUp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginTop="5dp"
        android:onClick="Click_buttonLogIn"/>




</androidx.constraintlayout.widget.ConstraintLayout>