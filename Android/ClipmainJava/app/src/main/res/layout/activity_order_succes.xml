<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✅"
        android:textSize="64sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Заказ оформлен!"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/textViewOrderId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Заказ №0"
        android:textSize="18sp"
        android:textColor="#363676"
        android:layout_marginTop="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Мы свяжемся с вами для подтверждения"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginTop="16dp"
        android:gravity="center"/>

    <Button
        android:id="@+id/buttonToShop"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Вернуться в магазин"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#363676"
        android:layout_marginTop="32dp"/>

    <Button
        android:id="@+id/buttonToOrders"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Мои заказы"
        android:textColor="#363676"
        android:backgroundTint="#FFFFFF"
        android:layout_marginTop="8dp"/>

</LinearLayout>