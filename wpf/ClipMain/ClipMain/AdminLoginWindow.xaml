<Window x:Class="ClipMain.AdminLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClipMain"
        mc:Ignorable="d"
        Title="AdminLoginWindow" Height="450" Width="800">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Вход в админ-панель" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"
                   Foreground="DimGray"/>

        <TextBlock Grid.Row="1" Text="Номер телефона:" 
                   Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox Grid.Row="2" x:Name="PhoneBox" Height="32" 
                 Margin="0,0,0,10" FontSize="14"
                 MaxLength="11" HorizontalContentAlignment="Center"
                 TextChanged="PhoneBox_TextChanged"/>

        <TextBlock Grid.Row="3" Text="Код подтверждения:" 
                   Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox Grid.Row="4" x:Name="CodeBox" Height="32" 
                 Margin="0,0,0,5" FontSize="18"
                 MaxLength="4" HorizontalContentAlignment="Center"
                 TextAlignment="Center"/>

        <Grid Grid.Row="5" Margin="0,5,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Получить код" 
                    Click="SendCodeButton_Click" Height="38" 
                    Background="#2196F3" Foreground="White"
                    FontSize="14" FontWeight="Bold"
                    Cursor="Hand" Margin="0,0,10,0"
                    x:Name="SendCodeButton"/>

            <TextBlock Grid.Column="1" x:Name="TimerText" 
                       Text="" VerticalAlignment="Center"
                       FontSize="14" Foreground="Gray"
                       MinWidth="50" TextAlignment="Center"/>
        </Grid>

        <Button Grid.Row="6" Content="Войти" 
                Click="LoginButton_Click" Height="40"
                Background="#4CAF50" Foreground="White"
                FontSize="16" FontWeight="Bold"
                IsDefault="True" Cursor="Hand"
                x:Name="LoginButton" IsEnabled="False"/>

        <TextBlock Grid.Row="7" x:Name="StatusText" 
                   HorizontalAlignment="Center" 
                   Margin="0,15,0,0" 
                   Foreground="Gray" FontStyle="Italic"
                   TextWrapping="Wrap" TextAlignment="Center"/>

        <CheckBox Grid.Row="8" x:Name="DevModeCheckBox"
                  Content="Режим разработчика (код: 1234)"
                  HorizontalAlignment="Center" Margin="0,10,0,0"
                  Foreground="Gray" FontSize="11"
                  Checked="DevModeCheckBox_Checked"
                  Unchecked="DevModeCheckBox_Unchecked"/>
    </Grid>
</Window>
