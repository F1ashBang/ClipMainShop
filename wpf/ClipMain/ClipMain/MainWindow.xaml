<Window x:Class="ClipMain.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClipMain"
        mc:Ignorable="d"
        Title="Admin Panel" Height="700" Width="1000">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Админ-панель" FontSize="22" FontWeight="Bold" 
                       VerticalAlignment="Center" Margin="0,0,30,0"/>
            <Button Content="🔄 Обновить всё" Name="RefreshAllButton"  Click="RefreshAllButton_Click" 
                    Width="140" Height="32" Margin="0,0,10,0"/>
            <Button Content="🚪 Выйти" Click="Logout_Click" 
                    Width="100" Height="32" Background="#F44336" Foreground="White"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="📦 Товары">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Управление товарами" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Content="+ Добавить товар" Click="addProduct_Click" 
                    Width="160" Height="32"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold"
                    Margin="0,0,10,0"/>
                        <Button Content="🔄 Обновить" Click="refreshButton_Click" 
                    Width="120" Height="32"/>
                    </StackPanel>

                    <ListView Grid.Row="1" x:Name="ProductsListView" 
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" 
                               ItemWidth="280" ItemHeight="450"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="4"
                                    Background="White" CornerRadius="12"
                                    BorderBrush="#E0E0E0" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" Opacity="0.15" BlurRadius="8"/>
                                    </Border.Effect>

                                    <Grid Margin="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="200"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Image Grid.Row="0" 
                                        Source="{Binding FirstImagePath}"
                                        Stretch="UniformToFill"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                        <TextBlock Grid.Row="1" 
                                        Text="{Binding Title}"
                                        FontSize="16" FontWeight="Bold"
                                        Margin="15,10,15,0"
                                        TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Row="2" 
                                        Text="{Binding PriceString}"
                                        FontSize="20" FontWeight="Bold"
                                        Foreground="#4CAF50"
                                        Margin="15,5,15,0"/>

                                        <TextBlock Grid.Row="3" 
                                        Text="{Binding Description}"
                                        FontSize="12" Foreground="#757575"
                                        Margin="15,8,15,0"
                                        TextTrimming="CharacterEllipsis"
                                        MaxHeight="50"/>

                                        <TextBlock Grid.Row="4" 
                                        Text="{Binding SizesString}"
                                        FontSize="12" Foreground="#757575"
                                        Margin="15,5,15,0"
                                        TextTrimming="CharacterEllipsis"/>          

                                        <TextBlock Grid.Row="5" 
                                        Text="{Binding StockString}"
                                        FontSize="12" FontWeight="Bold"
                                        Margin="15,5,15,0"> 
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StockString}" Value="Нет в наличии">
                                                            <Setter Property="Foreground" Value="Red"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StockString}" Value="Нет в наличии">
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Rectangle Grid.Row="6" Height="1" Fill="#E0E0E0"
                                       Margin="15,10,15,0" VerticalAlignment="Bottom"/>

                                        <StackPanel Grid.Row="6" Orientation="Horizontal" 
                                        HorizontalAlignment="Center" Margin="0,10,0,15">
                                            <Button Content="✏️ Изменить" 
                                                Click="editCardButton_Click"
                                                Tag="{Binding Id}"
                                                Width="110" Height="32"
                                                Background="#2196F3" Foreground="White"
                                                FontWeight="Bold" Margin="0,0,5,0"
                                                Cursor="Hand"/>
                                            <Button Content="🗑️ Удалить" 
                                                Click="deleteCardButton_Click"
                                                Tag="{Binding Id}"
                                                Width="110" Height="32"
                                                Background="#F44336" Foreground="White"
                                                FontWeight="Bold" Margin="5,0,0,0"
                                                Cursor="Hand"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabItem>
            <TabItem Header="👥 Пользователи">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Список пользователей" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Content="🔄 Обновить" Name="RefreshUsersButton" Click="RefreshUsersButton_Click"
                    Width="120" Height="32" Margin="0,0,10,0"/>
                        <Button Content="💾 Сохранить изменения" Name="SaveUsersButton" Click="SaveUsersButton_Click"
                    Width="200" Height="32" Background="#FF9800" Foreground="White"
                    FontWeight="Bold"/>
                    </StackPanel>

                    <ListView Grid.Row="1" x:Name="UsersListView"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" 
                               ItemWidth="300" ItemHeight="220"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Width="280" Height="200" Margin="10"
                            Background="White" CornerRadius="12"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="8"/>
                                    </Border.Effect>

                                    <Grid Margin="15">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Orientation="Horizontal" 
                                        HorizontalAlignment="Center" Margin="0,0,0,8">
                                            <TextBlock Text="ID: " FontWeight="Bold" FontSize="12" 
                                           Foreground="#888"/>
                                            <TextBlock Text="{Binding Id}" FontSize="12" 
                                           Foreground="#888"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" 
                                        Margin="0,0,0,8">
                                            <Border Width="50" Height="50" CornerRadius="25"
                                        Background="#2196F3" HorizontalAlignment="Center"
                                        Margin="0,0,0,5">
                                                <TextBlock Text="👤" FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White"/>
                                            </Border>
                                            <TextBlock Text="{Binding PhoneNumber}" 
                                           FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <Border Grid.Row="2" CornerRadius="5" Padding="8,3"
                                    HorizontalAlignment="Center" Margin="0,0,0,10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Verified}" Value="True">
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Verified}" Value="False">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Verified}" Value="True">
                                                                <Setter Property="Text" Value="✅ Подтверждён"/>
                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Verified}" Value="False">
                                                                <Setter Property="Text" Value="⏳ Не подтверждён"/>
                                                                <Setter Property="Foreground" Value="#E65100"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <CheckBox Grid.Row="3" 
                                      IsChecked="{Binding IsAdmin}"
                                      Content="Администратор"
                                      FontWeight="Bold" FontSize="14"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Foreground="#333"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock Grid.Row="2" 
                   Text="Для изменения прав — поставьте/уберите галочку и нажмите «Сохранить изменения»"
                   Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                </Grid>
            </TabItem>
            <TabItem Header="📋 Заказы">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Список заказов" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Name="RefreshOrders" Content="🔄 Обновить" Click="RefreshOrders_Click"
                    Width="120" Height="32" Margin="0,0,10,0"/>
                        <ComboBox x:Name="FilterStatus" Width="150" Height="32"
                      SelectionChanged="FilterStatus_SelectionChanged">
                            <ComboBoxItem Content="Все" IsSelected="True"/>
                            <ComboBoxItem Content="Новые"/>
                            <ComboBoxItem Content="В обработке"/>
                            <ComboBoxItem Content="В пути"/>
                            <ComboBoxItem Content="Доставлен"/>
                            <ComboBoxItem Content="Отменён"/>
                        </ComboBox>
                    </StackPanel>

                    <ListView Grid.Row="1" x:Name="OrdersListView"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="350"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Width="330" MinHeight="260" Margin="10"
                            Background="White" CornerRadius="12"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="8"/>
                                    </Border.Effect>

                                    <Grid Margin="15">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Orientation="Horizontal"
                                        HorizontalAlignment="Center" Margin="0,0,0,10">
                                            <TextBlock FontWeight="Bold" FontSize="16"
                                           Foreground="#363676">
                                                <Run Text="Заказ №"/>
                                                <Run Text="{Binding Id, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <Border Grid.Row="1" CornerRadius="5" Padding="10,4"
                                    HorizontalAlignment="Center" Margin="0,0,0,10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="new">
                                                            <Setter Property="Background" Value="#E3F2FD"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="processing">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="shipped">
                                                            <Setter Property="Background" Value="#F3E5F5"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="delivered">
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="cancelled">
                                                            <Setter Property="Background" Value="#FFEBEE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontWeight="Bold" FontSize="13">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="new">
                                                                <Setter Property="Text" Value="🆕 Новый"/>
                                                                <Setter Property="Foreground" Value="#1565C0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="processing">
                                                                <Setter Property="Text" Value="⚙️ В обработке"/>
                                                                <Setter Property="Foreground" Value="#E65100"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="shipped">
                                                                <Setter Property="Text" Value="🚚 В пути"/>
                                                                <Setter Property="Foreground" Value="#7B1FA2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="delivered">
                                                                <Setter Property="Text" Value="✅ Доставлен"/>
                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="cancelled">
                                                                <Setter Property="Text" Value="❌ Отменён"/>
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Grid.Row="2" FontSize="11" Foreground="#C62828"
                                           HorizontalAlignment="Center"
                                           Margin="0,3,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="300"
                                           Text="{Binding CancellationReason, Mode=OneWay}"/>

                                        <TextBlock Grid.Row="3" FontSize="13" Foreground="#555"
                                                       HorizontalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding FirstName}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding LastName}"/>
                                        </TextBlock>

                                        <StackPanel Grid.Row="4" Orientation="Vertical"
                                            HorizontalAlignment="Center" Margin="0,5,0,0">

                                            <Expander Margin="0,0,0,5" MaxHeight="150">
                                                <Expander.Header>
                                                    <TextBlock FontSize="13" Foreground="#888">
                                                        <Run Text="{Binding ItemsCount, Mode=OneWay}"/>
                                                        <Run Text=" товаров"/>
                                                    </TextBlock>
                                                </Expander.Header>
                                                <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                                                    <TextBlock FontSize="12" Foreground="#555" 
                                                       Text="{Binding ItemsDisplay, Mode=OneWay}"
                                                       Margin="10,5,0,0"
                                                       TextWrapping="Wrap"/>
                                                </ScrollViewer>
                                            </Expander>

                                            <TextBlock FontSize="14" FontWeight="Bold"
                                                   Foreground="#363676"
                                                   HorizontalAlignment="Center">
                                            <Run Text="{Binding TotalPriceString, Mode=OneWay}"/>
                                            </TextBlock>

                                        </StackPanel>

                                        <TextBlock Grid.Row="5" FontSize="11" Foreground="#AAA"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Bottom"
                                       Text="{Binding CreatedAt}"/>
                                        
                                        <StackPanel Grid.Row="6" Orientation="Horizontal"
                                        HorizontalAlignment="Center" Margin="0,10,0,0">
                                            <ComboBox x:Name="StatusCombo" Width="130" Height="28"
                                                Tag="{Binding Id}"
                                                SelectedValue="{Binding Status, Mode=OneWay}"
                                                SelectionChanged="StatusCombo_SelectionChanged">
                                                <ComboBoxItem Content="Новый" Tag="new"/>
                                                <ComboBoxItem Content="В обработке" Tag="processing"/>
                                                <ComboBoxItem Content="В пути" Tag="shipped"/>
                                                <ComboBoxItem Content="Доставлен" Tag="delivered"/>
                                                <ComboBoxItem Content="Отменён" Tag="cancelled"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    
                    <TextBlock Grid.Row="2" Text="Для смены статуса — выберите новый статус из списка"
                   Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                </Grid>
            </TabItem>

        </TabControl>
        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="🟢Готово!"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
